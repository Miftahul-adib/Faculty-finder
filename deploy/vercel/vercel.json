{
  "framework": null,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/ask", "destination": "/api/index" },
    { "source": "/ask-stream", "destination": "/api/index" },
    { "source": "/ask-phd", "destination": "/api/index" },
    { "source": "/ask-phd-stream", "destination": "/api/index" },
    { "source": "/auth/:path*", "destination": "/api/index" },
    { "source": "/student/:path*", "destination": "/api/index" },
    { "source": "/phd-students", "destination": "/api/index" },
    { "source": "/phd-students/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
