{
  "name": "Python 3",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "frontend/src/App.jsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; (cd frontend && npm install); echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": {
    "backend": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8000",
    "frontend": "cd frontend && npm run dev -- --host 0.0.0.0"
  },
  "portsAttributes": {
    "5173": {
      "label": "Application",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "Backend API"
    }
  },
  "forwardPorts": [
    5173,
    8000
  ]
}
